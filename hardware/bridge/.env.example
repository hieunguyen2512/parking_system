# Serial ports – xem trong Device Manager
ENTRY_SERIAL_PORT=COM3
EXIT_SERIAL_PORT=COM4
SERIAL_BAUD=9600

# AI Service
AI_SERVICE_URL=http://localhost:5001
AI_TIMEOUT_MS=10000

# Backend
BACKEND_URL=http://localhost:4000
HARDWARE_API_KEY=parking_hw_secret_change_this

# WebSocket server (real-time cho Admin Web)
WS_PORT=4002

# ID thiết bị (phải trùng với device_id trong bảng devices)
ENTRY_DEVICE_ID=1
EXIT_DEVICE_ID=2

# Debounce (ms): tránh xử lý liên tục khi sensor dao động
DEBOUNCE_MS=3000
